# Database - PostgreSQL connection (use DATABASE_URL or individual vars)
DATABASE_URL=
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ballim
DB_USER=
DB_PASSWORD=

# Authentication - REQUIRED in production
JWT_SECRET=
ADMIN_USERNAME=
ADMIN_PASSWORD=

# Email - Resend (optional, logs to console if not set)
RESEND_API_KEY=
FROM_EMAIL=noreply@ballim.com
ADMIN_EMAIL=

# Environment
NODE_ENV=development

# Optional - Vercel
VERCEL_URL=
